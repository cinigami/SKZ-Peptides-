# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_from_botfather
WEBHOOK_URL=https://yourdomain.com/webhook

# Payment Gateway Configuration (Malaysian)
# Choose one or multiple:

# Billplz (Popular in Malaysia)
BILLPLZ_API_KEY=your_billplz_api_key
BILLPLZ_COLLECTION_ID=your_collection_id
BILLPLZ_X_SIGNATURE_KEY=your_signature_key

# iPay88 (Comprehensive Malaysian gateway)
IPAY88_MERCHANT_CODE=your_merchant_code
IPAY88_MERCHANT_KEY=your_merchant_key
IPAY88_SANDBOX=true

# Database
DATABASE_URL=./skz_orders.db

# Website Integration
WEBSITE_API_URL=http://localhost:3000/api

# Admin Settings
ADMIN_CHAT_IDS=753142813
CURRENCY=MYR
SHIPPING_FEE=8